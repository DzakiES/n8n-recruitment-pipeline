    {
      "parameters": {
        "jsCode": "const crypto = require('crypto');\n\nconst raw = $input.first().json.content.parts[0].text;\nconst form = $('On form submission').first().json;\nconst cleaned = raw.replace(/```json\\n?/g, '').replace(/```/g, '').trim();\nconst ai = JSON.parse(cleaned);\n\n// Generate a unique token for this candidate\nconst token = crypto.randomBytes(32).toString('hex');\nconst email = encodeURIComponent(form['What is your Email']);\nconst name = encodeURIComponent(form['What is your name']);\n\nreturn [{\n  json: {\n    name: form['What is your name'],\n    email: form['What is your Email'],\n    phone: form['Phone Number [e.g. +62 1234567890]'],\n    experience: form['Do you have any experience?'],\n    skills: form['Tell us about your skills'],\n    ai_score: ai.score,\n    qualified: ai.qualified,\n    strengths: ai.strengths,\n    concerns: ai.concerns,\n    recommended_action: ai.recommended_action,\n    applied_at: new Date().toISOString(),\n    interview_date: '',\n    approval_token: token,  // ← store this in Google Sheets\n    approve_url: `https://dzakies.app.n8n.cloud/webhook/approve?email=${email}&name=${name}&token=${token}`,\n    reject_url: `https://dzakies.app.n8n.cloud/webhook/reject?email=${email}&name=${name}&token=${token}`,\n  }\n}];"
      },
