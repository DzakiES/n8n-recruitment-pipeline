    {
      "parameters": {
        "sendTo": "={{ $json.Email }}",
        "subject": "Thank You for Applying — We've Received Your Application!",
        "message": "=<!DOCTYPE html>\n<html>\n<body style=\"margin:0;padding:0;background-color:#f4f6f9;font-family:Arial,sans-serif;\">\n  <div style=\"max-width:600px;margin:40px auto;background:#ffffff;border-radius:12px;overflow:hidden;box-shadow:0 2px 8px rgba(0,0,0,0.08);\">\n    \n    <!-- Header -->\n    <div style=\"background:linear-gradient(135deg,#1d4ed8,#3b82f6);padding:40px 32px;text-align:center;\">\n      <h1 style=\"margin:0;color:#ffffff;font-size:24px;font-weight:600;\">Application Received! 🎉</h1>\n      <p style=\"margin:8px 0 0;color:#bfdbfe;font-size:14px;\">We're excited to review your profile</p>\n    </div>\n\n    <!-- Body -->\n    <div style=\"padding:32px;\">\n      <p style=\"margin:0 0 16px;font-size:15px;color:#374151;\">Hi <strong>{{ $json.Name }}</strong>,</p>\n      <p style=\"margin:0 0 24px;font-size:14px;color:#6b7280;line-height:1.6;\">\n        Thank you for applying! We've successfully received your application and our team is currently reviewing it. We'll be in touch soon with the next steps.\n      </p>\n\n      <!-- Summary Card -->\n      <div style=\"background:#f8fafc;border:1px solid #e5e7eb;border-radius:8px;padding:20px;margin-bottom:24px;\">\n        <p style=\"margin:0 0 12px;font-size:13px;font-weight:600;color:#1d4ed8;text-transform:uppercase;letter-spacing:0.5px;\">Your Submission Summary</p>\n        <table style=\"width:100%;font-size:13px;border-collapse:collapse;\">\n          <tr>\n            <td style=\"padding:8px 0;color:#9ca3af;width:110px;vertical-align:top;\">Name</td>\n            <td style=\"padding:8px 0;color:#111827;font-weight:500;\">{{ $json.Name }}</td>\n          </tr>\n          <tr style=\"border-top:1px solid #f0f0f0;\">\n            <td style=\"padding:8px 0;color:#9ca3af;vertical-align:top;\">Email</td>\n            <td style=\"padding:8px 0;color:#111827;\">{{ $json.Email }}</td>\n          </tr>\n          <tr style=\"border-top:1px solid #f0f0f0;\">\n            <td style=\"padding:8px 0;color:#9ca3af;vertical-align:top;\">Phone</td>\n            <td style=\"padding:8px 0;color:#111827;\">{{ $json.Phone }}</td>\n          </tr>\n          <tr style=\"border-top:1px solid #f0f0f0;\">\n            <td style=\"padding:8px 0;color:#9ca3af;vertical-align:top;\">Experience</td>\n            <td style=\"padding:8px 0;color:#111827;\">{{ $json['Experience '] }}</td>\n          </tr>\n          <tr style=\"border-top:1px solid #f0f0f0;\">\n            <td style=\"padding:8px 0;color:#9ca3af;vertical-align:top;\">Skills</td>\n            <td style=\"padding:8px 0;color:#111827;\">{{ $json.Skills }}</td>\n          </tr>\n        </table>\n      </div>\n\n      <!-- What's Next -->\n      <div style=\"background:#eff6ff;border-left:4px solid #3b82f6;border-radius:0 8px 8px 0;padding:16px 20px;margin-bottom:24px;\">\n        <p style=\"margin:0 0 8px;font-size:13px;font-weight:600;color:#1d4ed8;\">What happens next?</p>\n        <ol style=\"margin:0;padding-left:18px;font-size:13px;color:#374151;line-height:1.8;\">\n          <li>Our team reviews your application</li>\n          <li>You'll receive an email with the decision</li>\n          <li>If selected, we'll schedule an interview</li>\n        </ol>\n      </div>\n\n      <p style=\"margin:0;font-size:13px;color:#6b7280;\">\n        If you have any questions, feel free to reply to this email.\n      </p>\n    </div>\n\n    <!-- Footer -->\n    <div style=\"background:#f9fafb;border-top:1px solid #e5e7eb;padding:20px 32px;text-align:center;\">\n      <p style=\"margin:0;font-size:12px;color:#9ca3af;\">\n        This is an automated message — please do not reply directly.<br/>\n        © {{ new Date().getFullYear() }} Recruitment Team. All rights reserved.\n      </p>\n    </div>\n\n  </div>\n</body>\n</html>",
