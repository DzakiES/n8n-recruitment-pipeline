    {
      "parameters": {
        "jsCode": "const candidates = $input.all();\n\nlet candidateRows = '';\n\ncandidates.forEach(c => {\n  const d = c.json;\n  const approveUrl = 'https://dzakies.app.n8n.cloud/webhook/approve?email=' + encodeURIComponent(d.Email) + '&name=' + encodeURIComponent(d.Name) + '&token=' + encodeURIComponent(d.Token);\nconst rejectUrl = 'https://dzakies.app.n8n.cloud/webhook/reject?email=' + encodeURIComponent(d.Email) + '&name=' + encodeURIComponent(d.Name) + '&token=' + encodeURIComponent(d.Token);\n\n  candidateRows += `\n    <div style=\"background:#fff;border:1px solid #e5e7eb;border-radius:8px;padding:20px;margin-bottom:16px;\">\n      \n      <div style=\"display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:12px;\">\n        <div>\n          <p style=\"margin:0;font-size:16px;font-weight:500;\">${d.Name}</p>\n          <p style=\"margin:0;font-size:13px;color:#888;\">${d.Email} · ${d.Phone}</p>\n        </div>\n        <div style=\"background:#f0f7ff;padding:6px 14px;border-radius:20px;font-size:13px;font-weight:500;color:#1d4ed8;\">\n          Score: ${d.Score}/100\n        </div>\n      </div>\n\n      <table style=\"width:100%;font-size:13px;margin-bottom:12px;\">\n        <tr>\n          <td style=\"color:#888;padding:4px 0;width:120px;\">Experience</td>\n          <td style=\"padding:4px 0;\">${d.Experience}</td>\n        </tr>\n        <tr>\n          <td style=\"color:#888;padding:4px 0;\">Skills</td>\n          <td style=\"padding:4px 0;\">${d.Skills}</td>\n        </tr>\n        <tr>\n          <td style=\"color:#888;padding:4px 0;\">AI Suggests</td>\n          <td style=\"padding:4px 0;font-weight:500;color:${d['AI Suggest'] === 'invite' ? '#16a34a' : '#dc2626'};\">${d['AI Suggest']}</td>\n        </tr>\n      </table>\n\n      <div style=\"background:#f0f7ff;border-left:3px solid #3b82f6;padding:10px 14px;border-radius:0 6px 6px 0;margin-bottom:8px;\">\n        <p style=\"margin:0;font-size:12px;font-weight:500;color:#1d4ed8;\">Strengths</p>\n        <p style=\"margin:4px 0 0;font-size:12px;\">${d.Strengths}</p>\n      </div>\n\n      <div style=\"background:#fff5f5;border-left:3px solid #ef4444;padding:10px 14px;border-radius:0 6px 6px 0;margin-bottom:16px;\">\n        <p style=\"margin:0;font-size:12px;font-weight:500;color:#dc2626;\">Concerns</p>\n        <p style=\"margin:4px 0 0;font-size:12px;\">${d.Concern}</p>\n      </div>\n\n      <a href=\"${approveUrl}\" style=\"display:inline-block;padding:10px 20px;background:#22c55e;color:white;text-decoration:none;border-radius:6px;font-weight:500;font-size:13px;margin-right:8px;\">\n        ✓ Approve\n      </a>\n      <a href=\"${rejectUrl}\" style=\"display:inline-block;padding:10px 20px;background:#ef4444;color:white;text-decoration:none;border-radius:6px;font-weight:500;font-size:13px;\">\n        ✗ Reject\n      </a>\n\n    </div>\n  `;\n});\n\nconst fullEmail = `\n<div style=\"font-family:Arial,sans-serif;max-width:680px;padding:20px;color:#333;\">\n  \n  <h2 style=\"font-size:20px;font-weight:500;margin-bottom:4px;\">Daily recruitment digest</h2>\n  <p style=\"color:#888;font-size:13px;margin-bottom:24px;\">${candidates.length} candidate${candidates.length > 1 ? 's' : ''} pending your review — ${new Date().toDateString()}</p>\n\n  ${candidateRows}\n\n  <p style=\"font-size:11px;color:#bbb;margin-top:24px;border-top:1px solid #eee;padding-top:16px;\">\n    This digest is sent automatically every day at 9am. Candidates with no decision after 48 hours will receive a follow-up from the system.\n  </p>\n\n</div>\n`;\n\nreturn [{ json: { emailHtml: fullEmail, count: candidates.length } }];"
      },
