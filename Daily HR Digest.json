      "parameters": {
        "sendTo": "={{ $json.Email }}",
        "subject": "You've been shortlisted! — Software Developer Role",
        "message": "=<div style=\"font-family:Arial,sans-serif;max-width:600px;padding:20px;color:#333;line-height:1.7;\">    <h2 style=\"font-size:18px;font-weight:500;color:#16a34a;\">Great news, {{ $json.Email }}! 🎉</h2>    <p>Thank you for applying for the <strong>Software Developer</strong> position. After carefully reviewing your application and CV, we're excited to invite you to the next stage of our recruitment process.</p>    <div style=\"background:#f0fdf4;border-left:4px solid #22c55e;padding:14px 18px;border-radius:0 8px 8px 0;margin:20px 0;\">     <p style=\"margin:0 0 6px;font-weight:500;font-size:13px;color:#16a34a;\">What happens next</p>     <p style=\"margin:0;font-size:13px;\">Our team will reach out within <strong>1-2 business days</strong> with the interview date, time, and video call link. The interview will take approximately 45-60 minutes.</p>   </div>    <p>In the meantime, please reply to this email to confirm you're still interested and available for an interview this week or next.</p>    <p>We look forward to speaking with you!</p>    <p>Talk soon,<br>   <strong>The Hiring Team</strong></p>    <hr style=\"border:none;border-top:1px solid #eee;margin:24px 0;\">   <p style=\"font-size:11px;color:#bbb;\">This email was sent automatically via our recruitment pipeline. Please reply directly to this email if you have any questions.</p>  </div>",
        "options": {}
      },
